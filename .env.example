# Contact form email service
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=

# Contact form rate limiting
# Create a Redis database at https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# Where contact form submissions are sent
TO_EMAIL=daniel.anth.est.03@gmail.com

# Optional: branded auto-reply sent back to people who submit the form.
# Leave unset to disable. Requires a VERIFIED sending domain in Resend
# (https://resend.com/domains) — the shared onboarding@resend.dev sandbox
# address can only deliver to the account owner, not to third parties.
# Example: CONTACT_AUTOREPLY_FROM="Daniel Estrella <hello@your-verified-domain.com>"
CONTACT_AUTOREPLY_FROM=

# GitHub Activity panel (home page)
# PAT for reading your own public GitHub data (contribution calendar,
# pinned repos, followers, top languages). Use viewer-scoped access.
# Classic PAT scopes: read:user + public_repo  (token starts ghp_)
# Fine-grained PAT: read-only "Account profile" + "Repositories" (github_pat_)
# Leave unset to gracefully hide the GitHub Activity section.
GITHUB_TOKEN=
